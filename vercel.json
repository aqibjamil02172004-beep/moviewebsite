{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.themoviedb.org https://db.videasy.net https://api.tvmaze.com https://www.wikidata.org https://query.wikidata.org https://www.omdbapi.com https://api.agregarr.org https://v3.sg.media-imdb.com; frame-src https://www.vidking.net; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), autoplay=(self \"https://www.vidking.net\"), fullscreen=(self \"https://www.vidking.net\"), picture-in-picture=(self \"https://www.vidking.net\")"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "functions": {
    "api/seo.js": {
      "includeFiles": "public/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/movie/:slug*",
      "destination": "/api/seo?route=movie&slug=:slug*"
    },
    {
      "source": "/tv/:slug*",
      "destination": "/api/seo?route=tvslug&slug=:slug*"
    },
    {
      "source": "/genre/:slug*",
      "destination": "/api/seo?route=genre&slug=:slug*"
    },
    {
      "source": "/actor/:slug*",
      "destination": "/api/seo?route=actor&slug=:slug*"
    },
    {
      "source": "/title/:id*",
      "destination": "/api/seo?route=title&id=:id*"
    },
    {
      "source": "/category/:category*",
      "destination": "/api/seo?route=category&category=:category*"
    },
    {
      "source": "/movies/:path*",
      "destination": "/api/seo?route=movies"
    },
    {
      "source": "/tv-shows/:path*",
      "destination": "/api/seo?route=tv"
    },
    {
      "source": "/watchlist/:path*",
      "destination": "/api/seo?route=watchlist"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
